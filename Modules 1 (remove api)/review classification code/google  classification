3. 时间特征：意大利旅游旺季（高概率游客）\n","# ===============================\n","tourist_months = [6, 7, 8, 9, 12]  # 夏季 + 圣诞季\n","\n","\n","# ===============================\n","# 4. 场景特征：长期 vs 短期体验\n","# ===============================\n","\n","# 长期体验（居民）\n","resident_context_patterns = [\n","    r\"\\b(i have been|been going|coming here) for \\d+ years\",\n","    r\"\\balways come\\b\",\n","    r\"\\blocal\\b\",\n","    r\"\\bregular\\b\",\n","]\n","\n","# 短期体验（游客）\n","tourist_context_patterns = [\n","    r\"\\btravel\\b\",\n","    r\"\\bon vacation\\b\",\n","    r\"\\btrip\\b\",\n","    r\"\\bitinerary\\b\",\n","    r\"\\bvisited\\b\",\n","]\n","\n","\n","# ===============================\n","# 5. 核心分类函数（整合所有因素）\n","# ===============================\n","def classify_review(text, date_str):\n","    text = str(text).lower().strip()\n","\n","    # ---------------------\n","    # a. 语言检测\n","    # ---------------------\n","    # 非意大利语且非英语 → 80% 概率是游客\n","    try:\n","        lang = detect(text)\n","        if lang not in [\"it\", \"en\"]:\n","            return \"tourist\"\n","    except:\n","        pass  # 检测失败则继续后续规则\n","\n","    # ---------------------\n","    # b. 居民关键词\n","    # ---------------------\n","    for kw in resident_keywords_it:\n","        if kw in text:\n","            return \"resident\"\n","\n","    # ---------------------\n","    # c. 游客关键词\n","    # ---------------------\n","    for kw in tourist_keywords_it_en:\n","        if kw in text:\n","            return \"tourist\"\n","\n","    # ---------------------\n","    # d. 场景（长期 vs 短期）分析\n","    # ---------------------\n","    for pat in resident_context_patterns:\n","        if re.search(pat, text):\n","            return \"resident\"\n","\n","    for pat in tourist_context_patterns:\n","        if re.search(pat, text):\n","            return \"tourist\"\n","\n","    # ---------------------\n","    # e. 评论长度（居民写更细节）\n","    # ---------------------\n","    if len(text.split()) > 80:\n","        resident_score = 1\n","    else:\n","        resident_score = 0\n","\n","    # ---------------------\n","    # f. 时间特征：旅游旺季\n","    # ---------------------\n","    try:\n","        month = pd.to_datetime(date_str).month\n","        if month in tourist_months:\n","            return \"tourist\"\n","    except:\n","        pass\n","\n","    # ---------------------\n","    # g. 最终默认规则（没命中任何特征 = 游客）\n","    # ---------------------\n","    if resident_score == 1:\n","        return \"resident\"\n","\n","    return \"tourist\"\n","\n","\n","# ===============================\n","# 6. 将函数应用到数据\n","# ===============================\n","df[\"user_type\"] = df.apply(lambda row: classify_review(row[\"review\"], row[\"date\"]), axis=1)\n","\n","# 输出前几行结果\n","print(df[[\"review\", \"user_type\"]].head(20))\n","\n","df.to_csv(\"reviews_classified_ALL_FEATURES.csv\", index=False)\n","print(\"✔ 已保存：reviews_classified_ALL_FEATURES.csv\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"btV2kO4UFBxD","executionInfo":{"status":"ok","timestamp":1765142734928,"user_tz":0,"elapsed":42402,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"48af9073-830d-4765-d57e-7a44f44a6d26"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["Requirement already satisfied: langdetect in /usr/local/lib/python3.12/dist-packages (1.0.9)\n","Requirement already satisfied: six in /usr/local/lib/python3.12/dist-packages (from langdetect) (1.17.0)\n","                                               review user_type\n","0   Amazing experience here! I highly recommend it...   tourist\n","1   Overall, we had a lovely dining experience at ...  resident\n","2   We had dinner here and everything was amazing....   tourist\n","3   I had a wonderful experience at this restauran...  resident\n","4   After traveling all over the world and experie...   tourist\n","5   Amazing food, atmosphere and service. We are v...  resident\n","6   My boyfriend and I truly enjoyed our meal at I...  resident\n","7   Absolutely fantastic place. The pasta is so de...   tourist\n","8   We order appetizer but they missed the order, ...  resident\n","9   Amazing food, service and atmosphere. This is ...   tourist\n","10  The food was excellent ¡ª full of flavor and b...   tourist\n","11  Better than expected ??. There are 2 restauran...   tourist\n","12  We went based on a friend's recommendation, an...   tourist\n","13  This restaurant is in a great location with so...   tourist\n","14  ?????????? Absolutely Excellent ¨C Came Back f...   tourist\n","15  We were very grateful that the staffs did the ...   tourist\n","16  Excellent food, stunning new location and same...   tourist\n","17  We visited AI Grill last year at the old locat...   tourist\n","18  If we could go back to any place in the world,...   tourist\n","19  Chic interior decor, nice jazz music in the ba...   tourist\n","✔ 已保存：reviews_classified_ALL_FEATURES.csv\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","import re\n","from datetime import datetime\n","\n","# -----------------------------------------------------------\n","# 1. 加载数据\n","# -----------------------------------------------------------\n","df = pd.read_csv(\"/content/zong.csv\", encoding='latin1')\n","\n","# 清洗空值\n","df['review'] = df['review'].fillna(\"\").astype(str)\n","df['title'] = df['title'].fillna(\"\").astype(str)\n","df['place_title'] = df['place_title'].fillna(\"\").astype(str)\n","df['name'] = df['name'].fillna(\"\").astype(str)\n","\n","\n","# -----------------------------------------------------------\n","# 2. 定义关键词词典\n","# -----------------------------------------------------------\n","\n","# “游客语气”\n","tourist_keywords = [\n","    r\"first time\", r\"must visit\", r\"bucket list\", r\"trip\", r\"travel\",\n","    r\"guidebook\", r\"amazing view\", r\"stunning\", r\"tour\", r\"crowded\",\n","    r\"worth visiting\", r\"postcard\", r\"beautiful place\", r\"photo spot\",\n","    r\"as a tourist\", r\"wander\", r\"explore\"\n","]\n","\n","# “居民语气”\n","resident_keywords = [\n","    r\"come here often\", r\"usually\", r\"every week\", r\"every day\", r\"daily\",\n","    r\"my neighborhood\", r\"near my home\", r\"local\", r\"our area\",\n","    r\"after work\", r\"lunch break\", r\"weekday\", r\"family dinner\",\n","    r\"used to be better\", r\"price increased\", r\"regular\", r\"grocery\",\n","    r\"my usual place\"\n","]\n","\n","# 景区类 place_title（游客更可能出现）\n","tourist_place_types = [\n","    \"church\", \"cathedral\", \"museum\", \"palace\", \"bridge\",\n","    \"attraction\", \"square\", \"monument\", \"landmark\", \"tower\",\n","    \"gallery\", \"tour\", \"boat\", \"gondola\"\n","]\n","\n","# 日常生活类 place_title（居民更可能出现）\n","resident_place_types = [\n","    \"supermarket\", \"pharmacy\", \"market\", \"bakery\", \"cafe\",\n","    \"restaurant\", \"bar\", \"laundry\", \"shop\"\n","]\n","\n","\n","# -----------------------------------------------------------\n","# 3. 辅助函数：关键字检测\n","# -----------------------------------------------------------\n","def contains_keywords(text, keyword_list):\n","    text = text.lower()\n","    return any(re.search(k, text) for k in keyword_list)\n","\n","\n","# -----------------------------------------------------------\n","# 4. 核心函数：判断是否游客\n","# -----------------------------------------------------------\n","def classify(row):\n","\n","    text = (row[\"review\"] + \" \" + row[\"title\"]).lower()\n","    place = row[\"place_title\"].lower()\n","    is_local_guide = str(row.get(\"local_guide\", \"\")).lower() in [\"1\", \"true\", \"yes\"]\n","\n","    # ---- Rule 1：游客语气（最强信号） ----\n","    if contains_keywords(text, tourist_keywords):\n","        return \"Tourist\"\n","\n","    # ---- Rule 2：居民语气（最强信号） ----\n","    if contains_keywords(text, resident_keywords):\n","        return \"Resident\"\n","\n","    # ---- Rule 3：地点类型判断 ----\n","    if any(w in place for w in tourist_place_types):\n","        return \"Tourist\"\n","    if any(w in place for w in resident_place_types):\n","        return \"Resident\"\n","\n","    # ---- Rule 4：Local Guide 行为 ----\n","    if is_local_guide:\n","        # Local Guide 通常游客，但要避免误判\n","        if row[\"likes\"] > 10:\n","            return \"Tourist\"\n","\n","    # ---- Rule 5：评分极端值 ----\n","    if row[\"rating\"] == 5:\n","        return \"Tourist\"\n","\n","    # ---- Rule 6：图片数量多的，一般是游客（尤其是景区）----\n","    if str(row[\"images\"]).count(\"http\") >= 3:\n","        return \"Tourist\"\n","\n","    # ---- Rule 7：时间行为：只有一条评论的很可能是游客 ----\n","    if df[df[\"name\"] == row[\"name\"]].shape[0] == 1:\n","        return \"Tourist\"\n","\n","    # 默认：居住者（因为游客一般会被规则覆盖）\n","    return \"Resident\"\n","\n","\n","# -----------------------------------------------------------\n","# 5. 执行分类\n","# -----------------------------------------------------------\n","df[\"label\"] = df.apply(classify, axis=1)\n","\n","# -----------------------------------------------------------\n","# 6. 输出结果\n","# -----------------------------------------------------------\n","df.to_csv(\"classified_output.csv\", index=False)\n","print(\"分类完成！文件已输出为 classified_output.csv\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"-oJ1GyYKu6PR","executionInfo":{"status":"ok","timestamp":1765143262154,"user_tz":0,"elapsed":6406,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"17a95804-385b-482d-b94a-a161a5443c1f"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["分类完成！文件已输出为 classified_output.csv\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"6d207153","executionInfo":{"status":"ok","timestamp":1765146802337,"user_tz":0,"elapsed":1602,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"85d8f605-434a-493b-c437-a248fef6e5fc"},"source":["import pandas as pd\n","import json\n","import re\n","from math import isfinite\n","\n","float_re = re.compile(r'[-+]?\\d*\\.\\d+|[-+]?\\d+')\n","\n","def find_two_floats(s):\n","    if pd.isna(s):\n","        return None\n","    s = str(s)\n","    # match two floats in string\n","    nums = float_re.findall(s)\n","    if len(nums) >= 2:\n","        try:\n","            a = float(nums[0])\n","            b = float(nums[1])\n","            return (a, b)\n","        except:\n","            return None\n","    return None\n","\n","def parse_wkt_point(s):\n","    # accepts \"POINT(lon lat)\" or \"POINT(lat lon)\"\n","    if not isinstance(s, str): return None\n","    m = re.search(r'POINT\\s*\\(\\s*([^\\s,]+)[\\s,]+([^\\s,]+)\\s*\\)', s, re.IGNORECASE)\n","    if m:\n","        try:\n","            a = float(m.group(1)); b = float(m.group(2))\n","            return (a, b)\n","        except:\n","            return None\n","    return None\n","\n","def valid_lat(x): return isfinite(x) and -90.0 <= x <= 90.0\n","def valid_lon(x): return isfinite(x) and -180.0 <= x <= 180.0\n","\n","def detect_and_get_lon_lat(row, gps_col, lat_col, lon_col, lon_first_flag):\n","    # priority: explicit lat/lon columns > WKT > gps string\n","    if lat_col and lon_col and lat_col in row.index and lon_col in row.index:\n","        lat = row[lat_col]; lon = row[lon_col]\n","        try:\n","            lat = float(lat); lon = float(lon)\n","            return lon, lat\n","        except:\n","            return None\n","\n","    # try WKT\n","    if gps_col and gps_col in row.index:\n","        s = row[gps_col]\n","        p = parse_wkt_point(s)\n","        if p:\n","            a,b = p\n","            if lon_first_flag:\n","                return a, b\n","            # heuristic: if first is lon-range and second lat-range, treat as lon,lat\n","            if valid_lon(a) and valid_lat(b):\n","                return a, b\n","            if valid_lat(a) and valid_lon(b):\n","                return b, a\n","            # fallback assume it's lon,lat (GeoJSON expects [lon, lat])\n","            return a, b\n","\n","        # try two floats\n","        p2 = find_two_floats(s)\n","        if p2:\n","            a,b = p2\n","            # heuristics:\n","            if valid_lat(a) and valid_lon(b) and not (valid_lon(a) and valid_lat(b)):\n","                # a looks like lat, b looks like lon -> swap\n","                return b, a\n","            if valid_lon(a) and valid_lat(b) and not (valid_lat(a) and valid_lon(b)):\n","                # a lon, b lat\n","                return a, b\n","            # ambiguous -> use lon_first_flag to decide; default assume a=lat,b=lon (common), but we will choose:\n","            if lon_first_flag:\n","                return a, b\n","            else:\n","                return b, a\n","\n","    return None\n","\n","def main():\n","    input_csv = \"/content/reviews_classified_ALL_FEATURES.csv\"\n","    output_geojson = \"/content/reviews_classified_ALL_FEATURES.geojson\"\n","    gps_col = \"gps\"\n","    lat_col = None\n","    lon_col = None\n","    lon_first_flag = False\n","    skip_invalid = True\n","\n","    df = pd.read_csv(input_csv, dtype=str)  # read all as string to be safe\n","\n","    # default gps column guess if not provided\n","    if not gps_col:\n","        for candidate in ['gps', 'location', 'coords', 'coordinate', 'geom', 'point']:\n","            if candidate in df.columns:\n","                gps_col = candidate\n","                break\n","    # default lat/lon candidates if user didn't specify\n","    if not lat_col or not lon_col:\n","        lat_candidates = ['lat','latitude','y']\n","        lon_candidates = ['lon','lng','long','longitude','x']\n","        if not lat_col:\n","            for c in lat_candidates:\n","                if c in df.columns:\n","                    lat_col = c; break\n","        if not lon_col:\n","            for c in lon_candidates:\n","                if c in df.columns:\n","                    lon_col = c; break\n","\n","    features = []\n","    errors = 0\n","    for idx, row in df.iterrows():\n","        coords = detect_and_get_lon_lat(row, gps_col, lat_col, lon_col, lon_first_flag)\n","        if coords is None:\n","            errors += 1\n","            if skip_invalid:\n","                continue\n","            else:\n","                raise ValueError(f\"Could not parse coordinates for row {idx}. \"\n","                                 f\"Try --gps-col/--lat-col/--lon-col or --lon-first. Row data: {row.to_dict()}\")\n","        lon, lat = coords\n","        if not (valid_lon(lon) and valid_lat(lat)):\n","            errors += 1\n","            if skip_invalid:\n","                continue\n","            else:\n","                raise ValueError(f\"Coordinates out of range for row {idx}: lon={lon}, lat={lat}\")\n","\n","        # build properties: keep all columns but remove gps/lat/lon fields to avoid duplication\n","        props = {}\n","        for c in df.columns:\n","            if c == gps_col or c == lat_col or c == lon_col:\n","                continue\n","            val = row[c]\n","            # try convert numbers to numeric\n","            if val is not None:\n","                val_str = str(val)\n","                # keep original strings, but try to cast ints/floats for nicer JSON\n","                if re.fullmatch(r'[-+]?\\d+', val_str):\n","                    props[c] = int(val_str)\n","                else:\n","                    try:\n","                        f = float(val_str)\n","                        props[c] = f\n","                    except:\n","                        props[c] = val_str\n","            else:\n","                props[c] = None\n","\n","        feature = {\n","            \"type\": \"Feature\",\n","            \"geometry\": {\"type\": \"Point\", \"coordinates\": [float(lon), float(lat)]},\n","            \"properties\": props\n","        }\n","        features.append(feature)\n","\n","    fc = {\"type\": \"FeatureCollection\", \"features\": features}\n","\n","    with open(output_geojson, \"w\", encoding=\"utf-8\") as f:\n","        json.dump(fc, f, ensure_ascii=False, indent=2)\n","\n","    print(f\"Wrote {len(features)} features to {output_geojson}. Rows skipped/failed: {errors}\")\n","\n","main()\n"],"execution_count":32,"outputs":[{"output_type":"stream","name":"stdout","text":["Wrote 9107 features to /content/reviews_classified_ALL_FEATURES.geojson. Rows skipped/failed: 6\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","import geopandas as gpd\n","from shapely.geometry import Point\n","import re # Import re for regex parsing\n","import numpy as np # Import numpy for NaN handling\n","\n","# Helper function to parse GPS string into lat, lng\n","def parse_gps_to_lat_lng(gps_str):\n","    if pd.isna(gps_str):\n","        return np.nan, np.nan\n","    s = str(gps_str).strip()\n","    # Try parsing \"POINT(lon lat)\" format (common for WKT)\n","    m = re.match(r'POINT\\(\\s*(-?\\d+\\.?\\d*)\\s+(-?\\d+\\.?\\d*)\\s*\\)', s, re.IGNORECASE)\n","    if m:\n","        lon = float(m.group(1))\n","        lat = float(m.group(2))\n","        return lat, lon\n","    # If not WKT, try simple comma separated \"lat,lng\" or \"lng,lat\" with heuristics\n","    parts = s.split(',')\n","    if len(parts) == 2:\n","        try:\n","            val1 = float(parts[0].strip())\n","            val2 = float(parts[1].strip())\n","            # Heuristic: assume lat,lon if values are in expected ranges\n","            if -90 <= val1 <= 90 and -180 <= val2 <= 180:\n","                return val1, val2 # lat, lng\n","            # Or lon,lat\n","            if -180 <= val1 <= 180 and -90 <= val2 <= 90:\n","                return val2, val1 # lat, lng\n","        except ValueError:\n","            pass # Fall through to return NaN if conversion fails\n","    return np.nan, np.nan\n","\n","# ---------------------------\n","# 1. 读取你的 CSV 文件\n","# ---------------------------\n","input_file = \"/content/classified_output3000.csv\" # Using the file from kernel state\n","df = pd.read_csv(input_file)\n","\n","# ---------------------------\n","# 2. 处理坐标，生成 lat 和 lng 列\n","# ---------------------------\n","# Apply the parsing function to create 'lat' and 'lng' columns\n","df['lat'], df['lng'] = zip(*df['gps'].apply(parse_gps_to_lat_lng))\n","\n","# Remove rows where lat or lng could not be parsed (after creating the columns)\n","df.dropna(subset=[\"lat\", \"lng\"], inplace=True)\n","\n","# ---------------------------\n","# 3. 生成 Point 几何对象\n","# ---------------------------\n","# Now that 'lat' and 'lng' exist and are clean, create the geometry\n","df[\"geometry\"] = df.apply(lambda row: Point(row[\"lng\"], row[\"lat\"]), axis=1)\n","\n","gdf = gpd.GeoDataFrame(df, geometry=\"geometry\", crs=\"EPSG:4326\")\n","\n","# ---------------------------\n","# 4. 分成“游客”和“居民”\n","# ---------------------------\n","# Use the 'label' column which was generated by the previous classification cells\n","tourists = gdf[gdf[\"label\"].str.lower() == \"tourist\"]\n","residents = gdf[gdf[\"label\"].str.lower() == \"resident\"]\n","\n","# ---------------------------\n","# 5. 保存为 CSV\n","# ---------------------------\n","tourists.to_csv(\"tourists.csv\", index=False, encoding=\"utf-8-sig\")\n","residents.to_csv(\"residents.csv\", index=False, encoding=\"utf-8-sig\")\n","\n","# ---------------------------\n","# 6. 保存为 GeoJSON\n","# ---------------------------\n","tourists.to_file(\"tourists.geojson\", driver=\"GeoJSON\")\n","residents.to_file(\"residents.geojson\", driver=\"GeoJSON\")\n","\n","print(\"Done! 已成功生成游客/居民的 CSV 和 GeoJSON 文件。\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"oy3VHUHZ_Q6-","executionInfo":{"status":"ok","timestamp":1765147531876,"user_tz":0,"elapsed":171,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"4b978a9f-9162-47fb-e5c1-4ebc33cf5757"},"execution_count":34,"outputs":[{"output_type":"stream","name":"stdout","text":["Done! 已成功生成游客/居民的 CSV 和 GeoJSON 文件。\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","import geopandas as gpd\n","import ast\n","from shapely.geometry import Point\n","\n","# -----------------------------\n","# 1. 读取你的 CSV 文件\n","# -----------------------------\n","df = pd.read_csv(\"/content/classified_output3000.csv\")   # ← 修改成你的文件名\n","\n","# -----------------------------\n","# 2. 解析 gps 字段 {'latitude': , 'longitude': }\n","# -----------------------------\n","def parse_gps(x):\n","    try:\n","        d = ast.literal_eval(x)\n","        return pd.Series([d.get(\"latitude\"), d.get(\"longitude\")])\n","    except:\n","        return pd.Series([None, None])\n","\n","df[[\"lat\", \"lng\"]] = df[\"gps\"].apply(parse_gps)\n","\n","# 删除没有坐标的数据\n","df = df.dropna(subset=[\"lat\", \"lng\"])\n","\n","# -----------------------------\n","# 3. 生成 GeoDataFrame\n","# -----------------------------\n","df[\"geometry\"] = df.apply(lambda row: Point(row[\"lng\"], row[\"lat\"]), axis=1)\n","gdf = gpd.GeoDataFrame(df, geometry=\"geometry\", crs=\"EPSG:4326\")\n","\n","# -----------------------------\n","# 4. 按 label 列拆分游客/居民\n","# -----------------------------\n","tourists = gdf[gdf[\"label\"].str.lower() == \"tourist\"]\n","residents = gdf[gdf[\"label\"].str.lower() == \"resident\"]\n","\n","# -----------------------------\n","# 5. 输出 CSV 文件\n","# -----------------------------\n","tourists.to_csv(\"tourists.csv\", index=False, encoding=\"utf-8-sig\")\n","residents.to_csv(\"residents.csv\", index=False, encoding=\"utf-8-sig\")\n","\n","# -----------------------------\n","# 6. 输出 GeoJSON 文件\n","# -----------------------------\n","tourists.to_file(\"tourists.geojson\", driver=\"GeoJSON\")\n","residents.to_file(\"residents.geojson\", driver=\"GeoJSON\")\n","\n","print(\"🎉 完成！已生成四个文件：tourists/residents 的 CSV + GeoJSON。\")\n"],"metadata":{"id":"DqZxRT0HA3Mf","executionInfo":{"status":"ok","timestamp":1765147913839,"user_tz":0,"elapsed":3658,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"57b2202e-862d