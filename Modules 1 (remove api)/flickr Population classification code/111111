,"\n","# -----------------------\n","# 5. 输出文件夹\n","# -----------------------\n","output_dir = \"geojson_by_year_month\"\n","os.makedirs(output_dir, exist_ok=True)\n","\n","# -----------------------\n","# 6. 按 年 × 月 × 用户类型 分组输出 GeoJSON\n","# -----------------------\n","for year in [2022, 2023, 2024, 2025]:\n","    for month in range(1, 13):\n","        for user_type in [\"RESIDENT\", \"TOURIST\"]: # Changed to uppercase to match 'classification' column\n","\n","            subset = gdf[\n","                (gdf[\"year\"] == year) &\n","                (gdf[\"month\"] == month) &\n","                (gdf[\"classification\"] == user_type) # Changed 'user_type' to 'classification'\n","            ]\n","\n","            if subset.empty:\n","                continue  # 跳过不存在的数据\n","\n","            file_name = f\"{user_type.lower()}_{year}_{month:02d}.geojson\" # Changed to lower for file name consistency\n","            subset.to_file(os.path.join(output_dir, file_name), driver=\"GeoJSON\")\n","\n","            print(\"Saved:\", file_name)\n","\n","print(\"All GeoJSON files created!\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"eU5bL-vxNnZJ","executionInfo":{"status":"ok","timestamp":1763760558699,"user_tz":0,"elapsed":983,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"e1ef2115-b53d-446d-90d6-f81472dc05ff"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Saved: resident_2022_01.geojson\n","Saved: tourist_2022_01.geojson\n","Saved: resident_2022_02.geojson\n","Saved: tourist_2022_02.geojson\n","Saved: resident_2022_03.geojson\n","Saved: tourist_2022_03.geojson\n","Saved: resident_2022_04.geojson\n","Saved: tourist_2022_04.geojson\n","Saved: resident_2022_05.geojson\n","Saved: resident_2022_06.geojson\n","Saved: tourist_2022_06.geojson\n","Saved: resident_2022_07.geojson\n","Saved: tourist_2022_07.geojson\n","Saved: resident_2022_08.geojson\n","Saved: tourist_2022_08.geojson\n","Save