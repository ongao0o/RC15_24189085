份列表\n","years = sorted(df[\"year\"].unique())\n","\n","# -------------------------------------\n","# 3. 定义：df → geojson 的函数\n","# -------------------------------------\n","def df_to_geojson(subdf):\n","    geojson = {\n","        \"type\": \"FeatureCollection\",\n","        \"features\": []\n","    }\n","    for _, row in subdf.iterrows():\n","        feature = {\n","            \"type\": \"Feature\",\n","            \"geometry\": {\n","                \"type\": \"Point\",\n","                \"coordinates\": [row[\"longitude\"], row[\"latitude\"]]\n","            },\n","            \"properties\": {\n","                \"owner\": row.get(\"owner\"),\n","                \"classification\": row.get(\"classification\"),\n","                \"year\": row.get(\"year\"),\n","                \"datetaken\": row.get(\"datetaken\").strftime(\"%Y-%m-%d\") if not pd.isna(row.get(\"datetaken\")) else None,\n","                \"title\": row.get(\"title\"), # Access 'title' if present in merged df\n","                \"description\": row.get(\"description\") # Access 'description' if present in merged df\n","                # Removed 'place' and 'rating' as they are not consistently in the merged data or original combined_data.csv\n","            }\n","        }\n","        geojson[\"features\"].append(feature)\n","    return geojson\n","\n","# -------------------------------------\n","# 4. 创建输出文件夹\n","# -------------------------------------\n","output_dir = \"geojson_by_year\"\n","os.makedirs(output_dir, exist_ok=True)\n","\n","# -------------------------------------\n","# 5. 按年份 × 分类 写出 GeoJSON\n","# -------------------------------------\n","for year in years:\n","    for user_type in [\"RESIDENT\", \"TOURIST\"]:\n","\n","        subdf = df[(df[\"year\"] == year) & (df[\"classification\"] == user_type)]\n","        if subdf.empty:\n","            continue\n","\n","        file_name = f\"{user_type}_{year}.geojson\"\n","        file_path = os.path.join(output_dir, file_name)\n"