 dates.min()).days\n","    else:\n","        day_span = 0\n","\n","    # 居民标准：\n","    #   (1) 城市内照片占比 >= 50%\n","    #   (2) 时间分布超过 90 天（不是短暂停留）\n","    if ratio >= 0.50 and day_span >= 90:\n","        cls = \"RESIDENT\"\n","    else:\n","        cls = \"TOURIST\"\n","\n","    return pd.Series({\n","        \"total_photos\": total_photos,\n","        \"city_photos\": city_photos,\n","        \"city_ratio\": ratio,\n","        \"day_span\": day_span,\n","        \"classification\": cls\n","    })\n","\n","# -------------------------------\n","# 4. 应用到每个用户\n","# -------------------------------\n","result = df.groupby(\"owner\").apply(classify_user, include_groups=False).reset_index()\n","\n","# -------------------------------\n","# 5. 输出结果\n","# -------------------------------\n","result.to_csv(\"/content/drive/MyDrive/flickr_user_classification2.csv\", index=False)\n","print(\"完成！输出文件：flickr_user_classification.csv\")"],"metadata":{"id":"tfXoEJu61U1y","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1765162163262,"user_tz":0,"elapsed":3897,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"118ee45f-2f33-4a09-db62-e94a1708be9e"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["完成！输出文件：flickr_user_classification.csv\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","import folium\n","from datetime import datetime\n","\n","# ------------------------------- General Constants (Can be moved to a config section) -------------------------------\n","CITY_LAT_MIN = 45.40\n","CITY_LAT_MAX = 45.46\n","CITY_LNG_MIN = 12.30\n","CITY_LNG_MAX = 12.37\n","\n","# ------------------------------- Function to check if a point is within the city bounds -------------------------------\n","def in_city(lat, lng):\n","    return (CITY_LAT_MIN <= lat <= CITY_LAT_MAX) and (CITY_LNG_MIN <= lng <= CITY_LNG_MAX)\n","\n","# ------------------------------- Function to classify users as Residents or Tourists -------------------------------\n","def classify_user(user_df):\n","    total_photos = len(user_df)\n","    city_photos = user_df['in_city'].sum()\n","    ratio = city_photos / total_photos\n","\n","    # Calculate time span of photos for the user\n","    dates = user_df['datetaken'].dropna()\n","    if len(dates) > 1:\n","        day_span = (dates.max() - dates.min()).days\n","    else:\n","        day_span = 0\n","\n","    # Classification criteria for a resident:\n","    # (1) At least 50% of photos are within the city\n","    # (2) Photo activity spans over 90 days (not a short visit)\n","    if ratio >= 0.50 and day_span >= 90:\n","        cls = \"RESIDENT\"\n","    else:\n","        cls = \"TOURIST\"\n","\n","    return pd.Series({\"classification\": cls})\n","\n","# -------------------------------\n","# 1. 读取原始照片数据并进行预处理\n","# -------------------------------\n","original_photos_df = pd.read_csv(\"/content/drive/MyDrive/fli/flikr combined_data.csv\", sep=',', on_bad_lines='skip')\n","original_photos_df['datetaken'] = pd.to_datetime(original_photos_df['date_taken'], errors='coerce')\n","\n","# Calculate 'in_city' status for each photo\n","original_photos_df['in_city'] = original_photos_df.apply(lambda r: in_city(r['latitude'], r['longitude']), axis=1)\n","\n","# -------------------------------\n","# 2. 对用户进行分类 (RESIDENT / TOURIST)\n","# -------------------------------\n","# Group by 'owner' and apply the classification function\n","user_classification_df = original_photos_df.groupby(\"owner\").apply(classify_user, include_groups=False).reset_index()\n","\n","# -------------------------------\n","# 3. 合并数据：将用户分类结果合并到照片数据中\n","# -------------------------------\n","df = original_photos_df.merge(user_classification_df[['owner', 'classification']], on='owner', how='left')\n","\n","# 确保经纬度列是数值类型，并过滤掉无效行\n","df['latitude'] = pd.to_numeric(df['latitude'], errors='coerce')\n","df['longitude'] = pd.to_numeric(df['longitude'], errors='coerce')\n","df.dropna(subset=['latitude', 'longitude', 'classification'], inplace=True)\n","\n","\n","# -------------------------------\n","# 4. Folium 地图可视化\n","# -------------------------------\n","# 默认中心设为威尼斯，可换\n","m = folium.Map(location=[45.44, 12.33], zoom_start=13)\n","\n","# 分类对应颜色\n","color_map = {\n","    \"RESIDENT\": \"blue\",\n","    \"TOURIST\": \"red\"\n","}\n","\n","# 为每个点添加 Marker\n","for _, row in df.iterrows():\n","    if row['classification'] in color_map:\n","        folium.CircleMarker(\n","            location=[row[\"latitude\"], row[\"longitude\"]],\n","            radius=4,\n","            color=color_map[row[\"classification\"]],\n","            fill=True,\n","            fill_opacity=0.7,\n","            popup=f\"User: {row['owner']}<br>Type: {row['classification']}\"\n","        ).add_to(m)\n","\n","# -------------------------------\n","# 5. 保存 html 文件\n","# -------------------------------\n","m.save(\"resident_vs_tourist_folium_map.html\")\n","print(\"完成！地图文件：resident_vs_tourist_folium_map.html\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"ZInRiAfoqT72","executionInfo":{"status":"ok","timestamp":1765162204158,"user_tz":0,"elapsed":27998,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"c22dce9a-8f71-47da-8e99-c9366a25b8a4"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["完成！地图文件：resident_vs_tourist_folium_map.html\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","import folium\n","from datetime import datetime\n","\n","# -------------------------------\n","# 1. 读取 CSV\n","# -------------------------------\n","df = pd.read_csv(\"/content/drive/MyDrive/fli/flikr combined_data.csv\", sep=',', on_bad_lines='skip')\n","df[\"datetaken\"] = pd.to_datetime(df[\"date_taken\"], errors=\"coerce\")\n","\n","# -------------------------------\n","# 2. 城市范围（以威尼斯为例，可换）\n","# -------------------------------\n","CITY_LAT_MIN, CITY_LAT_MAX = 45.40, 45.46\n","CITY_LNG_MIN, CITY_LNG_MAX = 12.30, 12.37\n","\n","def in_city(lat, lng):\n","    return (CITY_LAT_MIN <= lat <= CITY_LAT_MAX) and (CITY_LNG_MIN <= lng <= CITY_LNG_MAX)\n","\n","df[\"in_city\"] = df.apply(lambda r: in_city(r[\"latitude\"], r[\"longitude\"]), axis=1)\n","\n","\n","# -------------------------------\n","# 3. 居民 vs 游客 分类函数\n","# -------------------------------\n","def classify_user(user_df):\n","    total_photos = len(user_df)\n","    city_photos = user_df[\"in_city\"].sum()\n","    ratio = city_photos / total_photos\n","\n","    dates = user_df[\"datetaken\"].dropna()\n","    day_span = (dates.max() - dates.min()).days if len(dates) > 1 else 0\n","\n","    if ratio >= 0.50 and day_span >= 90:\n","        return \"RESIDENT\"\n","    else:\n","        return \"TOURIST\"\n","\n","\n","# -------------------------------\n","# 4. 给每个用户添加分类\n","# -------------------------------\n","user_class = df.groupby(\"owner\").apply(classify_user, include_groups=False).reset_index()\n","user_class.columns = [\"owner\", \"classification\"]\n","df = df.merge(user_class, on=\"owner\", how=\"left\")\n","\n","\n","# -------------------------------\n","# 5. Folium 地图（含两个图层）\n","# -------------------------------\n","m = folium.Map(location=[45.44, 12.33], zoom_start=13)\n","\n","# 创建两个图层\n","resident_layer = folium.FeatureGroup(name=\"Residents\")\n","tourist_layer = folium.FeatureGroup(name=\"Tourists\")\n","\n","# 颜色\n","color_map = {\n","    \"RESIDENT\": \"blue\",\n","    \"TOURIST\": \"red\"\n","}\n","\n","# 将点分别加入对应图层\n","for _, row in df.iterrows():\n","    # Ensure latitude, longitude, and classification are valid\n","    if pd.isna(row['latitude']) or pd.isna(row['longitude']) or pd.isna(row['classification']):\n","        continue\n","\n","    layer = resident_layer if row[\"classification\"] == \"RESIDENT\" else tourist_layer\n","\n","    folium.CircleMarker(\n","        location=[row[\"latitude\"], row[\"longitude\"]],\n","        radius=4,\n","        color=color_map[row[\"classification\"]],\n","        fill=True,\n","        fill_opacity=0.7,\n","        popup=f\"User: {row['owner']}<br>Type: {row['classification']}\"\n","    ).add_to(layer)\n","\n","# 把图层加到地图里\n","resident_layer.add_to(m)\n","tourist_layer.add_to(m)\n","\n","# 加图层控制器\n","folium.LayerControl().add_to(m)\n","\n","# -------------------------------\n","\n","# 在前面代码的基础上（df 已经带有 classification 字段）\n","\n","residents = df[df[\"classification\"] == \"RESIDENT\"]\n","tourists = df[df[\"classification\"] == \"TOURIST\"]\n","\n","residents.to_csv(\"resident_points.csv\", index=False)\n","tourists.to_csv(\"tourist_points.csv\", index=False)\n","\n","print(\"已生成：resident_points.csv 与 tourist_points.csv\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"l2yp28ULryAW","executionInfo":{"status":"ok","timestamp":1765162208898,"user_tz":0,"elapsed":4742,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"392d45e7-692c-4986-b6b8-434cf6699b34"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["已生成：resident_points.csv 与 tourist_points.csv\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","import json\n","\n","# -------------------------------\n","# 1. 读取原始 Flickr CSV 和用户分类结果\n","# -------------------------------\n","# 读取原始照片数据\n","original_photos_df = pd.read_csv(\"/content/drive/MyDrive/combined_data.csv\", sep=',', on_bad_lines='skip')\n","# 读取用户分类结果\n","user_classification_df = pd.read_csv(\"/content/drive/MyDrive/flickr_user_classification2.csv\")\n","\n","# 确保 classification 列存在于用户分类结果中\n","if \"classification\" not in user_classification_df.columns:\n","    raise ValueError(\"用户分类 CSV 需要包含 classification 列（RESIDENT / TOURIST）。\")\n","\n","# -------------------------------\n","# 2. 合并数据：将用户分类结果合并到照片数据中\n","# -------------------------------\n","df = original_photos_df.merge(user_classification_df[['owner', 'classification']], on='owner', how='left')\n","\n","# 确保经纬度列是数值类型，并过滤掉无效行\n","df['latitude'] = pd.to_numeric(df['latitude'], errors='coerce')\n","df['longitude'] = pd.to_numeric(df['longitude'], errors='coerce')\n","df.dropna(subset=['latitude', 'longitude', 'classification'], inplace=True)\n","\n","# -------------------------------\n","# 3. 定义函数：DataFrame → GeoJSON 字典\n","# -------------------------------\n","def df_to_geojson(subdf):\n","    geojson = {\n","        \"type\": \"FeatureCollection\",\n","        \"features\": []\n","    }\n","\n","    for _, row in subdf.iterrows():\n","        feature = {\n","            \"type\": \"Feature\",\n","            \"geometry\": {\n","                \"type\": \"Point\",\n","                \"coordinates\": [row[\"longitude\"], row[\"latitude\"]]\n","            },\n","            \"properties\": {\n","                \"owner\": row[\"owner\"],\n","                \"classification\": row[\"classification\"],\n","                \"datetaken\": str(row[\"datetaken\"]) if 'datetaken' in row and pd.notna(row[\"datetaken\"]) else None,\n","                \"title\": row[\"title\"] if 'title' in row else None,\n","                \"description\": row[\"description\"] if 'description' in row else None\n","            }\n","        }\n","        geojson[\"features\"].append(feature)\n","    return geojson\n","\n","# -------------------------------\n","# 4. 生成 GeoJSON\n","# -------------------------------\n","resident_geojson = df_to_geojson(df[df['classification'] == 'RESIDENT'])\n","tourist_geojson = df_to_geojson(df[df['classification'] == 'TOURIST'])\n","\n","# -------------------------------\n","# 5. 保存 GeoJSON 文件\n","# -------------------------------\n","with open('/content/drive/MyDrive/residents.geojson', 'w') as f:\n","    json.dump(resident_geojson, f, indent=2, ensure_ascii=False)\n","print(\"完成！居民 GeoJSON 文件：residents.geojson\")\n","\n","with open('/content/drive/MyDrive/tourists.geojson', 'w') as f:\n","    json.dump(tourist_geojson, f, indent=2, ensure_ascii=False)\n","print(\"完成！游客 GeoJSON 文件：tourists.geojson\")"