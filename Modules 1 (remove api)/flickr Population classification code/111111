rs='coerce')\n","df.dropna(subset=['latitude', 'longitude', 'datetaken', 'classification'], inplace=True)\n","\n","# Standardization of classification (uppercase) is already handled by merge if classification is consistent\n","df['classification'] = df['classification'].astype(str).str.upper()\n","\n","# -----------------------------\n","# 2. 过滤年份（只保留 2024 & 2025）\n","# -----------------------------\n","df[\"year\"] = df[\"datetaken\"].dt.year\n","df[\"month\"] = df[\"datetaken\"].dt.month\n","df = df[df[\"year\"].isin([2024, 2025])]\n","\n","if df.empty:\n","    raise SystemExit(\"筛选后无数据（没有 2024 或 2025 年的数据）。请检查 CSV 或列名配置。\")\n","\n","# -----------------------------\n","# 3. 准备地图中心（以点的平均位置为中心）\n","# -----------------------------\n","center_lat = df[\"latitude\"].mean()\n","center_lng = df[\"longitude\"].mean()\n","\n","m = folium.Map(location=[center_lat, center_lng], zoom_start=12)\n","\n","# 颜色映射（你可以改成别的颜色名）\n","COLOR_MAP = {\n","    \"RESIDENT\": \"blue\",\n","    \"TOURIST\": \"red\"\n","}\n","\n","# -----------------------------\n","# 4. 为每个 (year, month, classification) 创建一个图层，并用 MarkerCluster 收集点\n","# -----------------------------\n","# 按 年、月、类型 分组\n","groups = df.groupby([\"year\", \"month\", \"classification\"])\n","\n","# 用字典记录已创建的 FeatureGroup（用于 LayerControl）\n","layer_registry = {}\n","\n","for (year, month, classification), subdf in groups:\n","    # 只接受 RESIDENT / TOURIST（忽略其他意外分类）\n","    if classification not in COLOR_MAP:\n","        continue\n","\n","    # 图层名称 e.g. \"Residents – 2024-01\"\n","    pretty_type = \"Residents\" if classification == \"RESIDENT\" else \"Tourists\"\n","    layer_name = f\"{pretty_type} – {year}-{month:02d}\"\n","\n","    # 创建 FeatureGroup 并加入 MarkerCluster（让点更易浏览）\n","    fg = folium.FeatureGroup(name=layer_name, show=False)\n","    mc = MarkerCluster(name=f\"{layer_name}_cluster\").add_to(fg)\n","\n","    # 添加点到 MarkerCluster\n","    for _, row in subdf.iterrows():\n","        popup_html = (\n","            f\"<b>Owner:</b> {row.get('owner', '')}<br>\" +\n","            f\"<b>Type:</b> {classification}<br>\" +\n","            f\"<b>Date:</b> {row['datetaken'].strftime('%Y-%m-%d')}<br>\" +\n","            f\"<b>Coords:</b> {row['latitude']:.6f}, {row['longitude']:.6f}\"\n","        )\n","\n","        folium.Marker(\n","            location=[row[\"latitude\"], row[\"longitude\"]],\n","            popup=popup_html,\n","            icon=folium.Icon(color=COLOR_MAP[classification])\n","        ).add_to(mc)\n","\n","    # 把 FeatureGroup 注册并添加到地图\n","    layer_registry[layer_name] = fg\n","    fg.add_to(m)\n","\n","# -----------------------------\n","# 5. 添加图层控制器（全部展开）\n","# -----------------------------\n","folium.LayerControl(collapsed=False).add_to(m)\n","\n","# -----------------------------\n","# 6. 导出 HTML\n","# -----------------------------\n","m.save(OUTPUT_HTML)\n","print(f\"完成：已生成网页文件 -> {OUTPUT_HTML}\")\n","print(\"打开该文件即可在浏览器中交互查看年-月-类型分层点位（不生成 GeoJSON 文件）。\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"uo2B-BcGQwFi","executionInfo":{"status":"ok","timestamp":1763742898010,"user_tz":0,"elapsed":1531,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"344a752b-7fc9-4145-e7d1-99cd075c10d3"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["完成：已生成网页文件 -> resident_tourist_monthly_map.html\n","打开该文件即可在浏览器中交互查看年-月-类型分层点位（不生成 GeoJSON 文件）。\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","import json\n","\n","# ------------------------------------\n","# 1. 读取 CSV\n","# ------------------------------------\n","# 修正：将 CSV 路径改为实际存在的路径，并确保 'date_taken' 被正确转换为 'datetaken'\n","df = pd.read_csv(\"/content/drive/MyDrive/mix/combined_data.csv\", sep=',', on_bad_lines='skip')\n","df[\"datetaken\"] = pd.to_datetime(df[\"date_taken\"], errors=\"coerce\")\n","\n","# 提取月份\n","df[\"month\"] = df[\"datetaken\"].dt.month\n","\n","# 确保已有 classification 列 (需要先进行用户分类，这里假设 df 已经包含了 classification)\n","# 为了让这段代码独立运行，我们在此处添加了用户分类逻辑\n","# -------------------------------\n","# 2. 定义城市范围（以威尼斯为例）\n","# -------------------------------\n","CITY_LAT_MIN = 45.40\n","CITY_LAT_MAX = 45.46\n","CITY_LNG_MIN = 12.30\n","CITY_LNG_MAX = 12.37\n","\n","def in_city(lat, lng):\n","    return (CITY_LAT_MIN <= lat <= CITY_LAT_MAX) and (CITY_LNG_MIN <= lng <= CITY_LNG_MAX)\n","\n","df['in_city'] = df.apply(lambda r: in_city(r['latitude'], r['longitude']), axis=1)\n","\n","# -------------------------------\n","# 3. 定义判断函数（只有 RESIDENT 和 TOURIST）\n","# -------------------------------\n","def classify_user(user_df):\n","    total_photos = len(user_df)\n","    city_photos = user_df['in_city'].sum()\n","    ratio = city_photos / total_photos\n","\n","    # 时间分布跨度\n","    dates = user_df['datetaken'].dropna()\n","    if len(dates) > 1:\n","        day_span = (dates.max() - dates.min()).days\n","    else:\n","        day_span = 0\n","\n","    # 居民标准：\n","    #   (1) 城市内照片占比 >= 50%\n","    #   (2) 时间分布超过 90 天（不是短暂停留）\n","    if ratio >= 0.50 and day_span >= 90:\n","        cls = \"RESIDENT\"\n","    else:\n","        cls = \"TOURIST\"\n","\n","    return pd.Series({\n","        \"classification\": cls\n","    })\n","\n","# 应用到每个用户\n","user_classification_df = df.groupby(\"owner\").apply(classify_user, include_groups=False).reset_index()\n","\n","df = df.merge(user_classification_df[['owner', 'classification']], on='owner', how='left')\n","\n","# 确保经纬度列是数值类型，并过滤掉无效行\n","df['latitude'] = pd.to_numeric(df['latitude'], errors='coerce')\n","df['longitude'] = pd.to_numeric(df['longitude'], errors='coerce')\n","df.dropna(subset=['latitude', 'longitude', 'classification'], inplace=True)\n","\n","\n","# ------------------------------------\n","# 4. DF → GeoJSON 函数\n","# ------------------------------------\n","def df_to_geojson(subdf):\n","    geojson = {\n","        \"type\": \"FeatureCollection\",\n","        \"features\": []\n","    }\n","\n","    for _, row in subdf.iterrows():\n","        feature = {\n","            \"type\": \"Feature\",\n","            \"geometry\": {\n","                \"type\": \"Point\",\n","                \"coordinates\": [row[\"longitude\"], row[\"latitude\"]]\n","            },\n","            \"properties\": {\n","                \"owner\": row.get(\"owner\", None),\n","                \"classification\": row.get(\"classification\", None),\n","                \"datetaken\": str(row.get(\"datetaken\", None)) if pd.notna(row.get(\"datetaken\")) else None,\n","                \"place\": row.get(\"place_title\", None),\n","                \"rating\": row.get(\"rating\", None),\n","                \"month\": int(row[\"month\"])\n","            }\n","        }\n","        geojson[\"features\"].append(feature)\n","\n","    return geojson\n","\n","\n","# ------------------------------------\n","# 5. 按月份创建 24 个 GeoJSON\n","# ------------------------------------\n","output_folder = \"/content/drive/MyDrive/geojson_by_month\"\n","import os\n","os.makedirs(output_folder, exist_ok=True)\n","\n","for month in range(1, 13):\n","\n","    # 分居民与游客\n","    df_res_m = df[(df[\"classification\"] == \"RESIDENT\") & (df[\"month\"] == month)]\n","    df_tou_m = df[(df[\"classification\"] == \"TOURIST\") & (df[\"month\"] == month)]\n","\n","    # 转成 GeoJSON\n","    geo_res = df_to_geojson(df_res_m)\n","    geo_tou = df_to_geojson(df_tou_m)\n","\n","    # 输出文件名\n","    res_filename = os.path.join(output_folder, f\"resident_{month:02d}.geojson\")\n","    tou_filename = os.path.join(output_folder, f\"tourist_{month:02d}.geojson\")\n","\n","    # 写入文件\n","    with open(res_filename, \"w\", encoding=\"utf-8\") as f:\n","        json.dump(geo_res, f, ensure_ascii=False, indent=2)\n","\n","    with open(tou_filename, \"w\", encoding=\"utf-8\") as f:\n","        json.dump(geo_tou, f, ensure_ascii=False, indent=2)\n","\n","    print(f\"生成：{res_filename} , {tou_filename}\")\n","\n","print(f\"全部完成：24 个 GeoJSON 文件已输出到 {output_folder}/\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"MIUF3PgaXomQ","executionInfo":{"status":"ok","timestamp":1763761455934,"user_tz":0,"elapsed":3890,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"3521f596-12c2-4d69-d408-b5fb66bd9ffa"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["生成：/content/drive/MyDrive/geojson_by_month/resident_01.geojson , /content/drive/MyDrive/geojson_by_month/tourist_01.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_02.geojson , /content/drive/MyDrive/geojson_by_month/tourist_02.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_03.geojson , /content/drive/MyDrive/geojson_by_month/tourist_03.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_04.geojson , /content/drive/MyDrive/geojson_by_month/tourist_04.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_05.geojson , /content/drive/MyDrive/geojson_by_month/tourist_05.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_06.geojson , /content/drive/MyDrive/geojson_by_month/tourist_06.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_07.geojson , /content/drive/MyDrive/geojson_by_month/tourist_07.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_08.geojson , /content/drive/MyDrive/geojson_by_month/tourist_08.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_09.geojson , /content/drive/MyDrive/geojson_by_month/tourist_09.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_10.geojson , /content/drive/MyDrive/geojson_by_month/tourist_10.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_11.geojson , /content/drive/MyDrive/geojson_by_month/tourist_11.geojson\n","生成：/content/drive/MyDrive/geojson_by_month/resident_12.geojson , /content/drive/MyDrive/geojson_by_month/tourist_12.geojson\n","全部完成：24 个 GeoJSON 文件已输出到 /content/drive/MyDrive/geojson_by_month/\n"]}]},{"cell_type":"code","source":["import pandas as pd\n","import matplotlib.pyplot as plt\n","\n","# -------------------------------------\n","# 1. 读取 CSV 并进行数据预处理和用户分类\n","# -------------------------------------\n","# Load original photo data\n","# 修正：将CSV文件路径从 /content/drive/MyDrive/mix/combined_data.csv 改为 /content/drive/MyDrive/combined_data.csv\n","original_photos_df = pd.read_csv(\"/content/drive/MyDrive/combined_data.csv\", sep=',', on_bad_lines='skip')\n","# Convert 'date_taken' to datetime for original photos\n","original_photos_df['datetaken'] = pd.to_datetime(original_photos_df['date_taken'], errors='coerce')\n","\n","# 定义城市范围（以威尼斯为例）\n","CITY_LAT_MIN = 45.40\n","CITY_LAT_MAX = 45.46\n","CITY_LNG_MIN = 12.30\n","CITY_LNG_MAX = 12.37\n","\n","def in_city(lat, lng):\n","    return (CITY_LAT_MIN <= lat <= CITY_LAT_MAX) and (CITY_LNG_MIN <= lng <= CITY_LNG_MAX)\n","\n","original_photos_df['in_city'] = original_photos_df.apply(lambda r: in_city(r['latitude'], r['longitude']), axis=1)\n","\n","# 定义判断函数（只有 RESIDENT 和 TOURIST）\n","def classify_user(user_df):\n","    total_photos = len(user_df)\n","    city_photos = user_df['in_city'].sum()\n","    ratio = city_photos / total_photos\n","\n","    # 时间分布跨度\n","    dates = user_df['datetaken'].dropna()\n","    if len(dates) > 1:\n","        day_span = (dates.max() - dates.min()).days\n","    else:\n","        day_span = 0\n","\n","    # 居民标准：\n","    #   (1) 城市内照片占比 >= 50%\n","    #   (2) 时间分布超过 90 天（不是短暂停留）\n","    if ratio >= 0.50 and day_span >= 90:\n","        cls = \"RESIDENT\"\n","    else:\n","        cls = \"TOURIST\"\n","\n","    return pd.Series({\n","        \"classification\": cls\n","    })\n","\n","# 应用到每个用户\n","user_classification_df = original_photos_df.groupby(\"owner\").apply(classify_user, include_groups=False).reset_index()\n","\n","# 合并数据\n","df = original_photos_df.merge(user_classification_df[['owner', 'classification']], on='owner', how='left')\n","\n","# 确保经纬度列是数值类型，并过滤掉无效行\n","df['latitude'] = pd.to_numeric(df['latitude'], errors='coerce')\n","df['longitude'] = pd.to_numeric(df['longitude'], errors='coerce')\n","df.dropna(subset=['latitude', 'longitude', 'classification', 'datetaken'], inplace=True)\n","\n","# 提取月份\n","df[\"month\"] = df[\"datetaken\"].dt.month\n","\n","# -------------------------------------\n","# 2. 按月份统计两个类别的数量\n","# -------------------------------------\n","# 修正：将 'user_type' 改为 'classification'\n","monthly_counts = df.groupby(['month', 'classification']).size().unstack(fill_value=0)\n","\n","# 按月份排序\n","monthly_counts = monthly_counts.sort_index()\n","\n","# -------------------------------------\n","# 3. 画图\n","# -------------------------------------\n","plt.figure(figsize=(10, 6))\n","# 修正：将 'resident' 和 'tourist' 改为 'RESIDENT' 和 'TOURIST'\n","plt.plot(monthly_counts.index, monthly_counts['RESIDENT'], label='Residents')\n","plt.plot(monthly_counts.index, monthly_counts['TOURIST'], label='Tourists')\n","\n","plt.xlabel('Month')\n","plt.ylabel('Number of Photos')\n","plt.title('Residents vs Tourists by Month')\n","plt.xticks(range(1, 13))\n","plt.legend()\n","plt.grid(True)\n","plt.tight_layout()\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":378},"id":"E6Sbi6lwXnje","executionInfo":{"status":"ok","timestamp":1763772002002,"user_tz":0,"elapsed":1314,"user":{"displayName":"Han Dou","userId":"16727743236897715381"}},"outputId":"d80d4d4d-d884-475e-d1a9-3a7c78c35824"},"execution_count":null,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]}]}